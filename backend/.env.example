# Azure Cosmos DB Connection String
# Get this from Azure Portal → Cosmos DB Account → Connection Strings
MONGO_URI=mongodb://username:password@accountname.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retryWrites=false&maxIdleTimeMS=120000&appName=@accountname@

# JWT Secret for authentication
# Generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Server port
PORT=8080

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development
